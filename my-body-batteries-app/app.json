{
  "expo": {
    "name": "Body Batteries",
    "slug": "my-body-batteries-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0d0d1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bellybuilder.bodybatteries"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0d1a"
      },
      "package": "com.bellybuilder.bodybatteries",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0d0d1a"
        }
      ]
    ]
  }
}
